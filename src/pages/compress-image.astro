---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { phase0Routes } from '../data/routes';
import { generateBreadcrumbSchema } from '../lib/seo';
import { getHubBreadcrumbs } from '../lib/site-structure';

const title = 'Compress Image Guide - Current JPEG and PNG Workflows | LocalResizer';
const description = 'Compare the current live JPEG and PNG compression pages on LocalResizer, see what each page is best for, and choose the right target-size workflow.';
const breadcrumbItems = getHubBreadcrumbs('compress-image');
const breadcrumbSchema = generateBreadcrumbSchema(breadcrumbItems);
const compressRoutes = phase0Routes.filter((route) => route.action === 'compress');
---
<BaseLayout title={title} description={description} schemas={[breadcrumbSchema]}>
  <Breadcrumbs items={breadcrumbItems} />

  <article class="max-w-4xl mx-auto px-4 sm:px-5 py-10 sm:py-14">
    <div class="text-center mb-10">
      <span class="inline-block px-3 py-1 rounded-full bg-emerald-50 text-emerald-700 text-xs font-semibold tracking-wide uppercase mb-3">Guide</span>
      <h1 class="font-[var(--font-heading)] text-3xl md:text-4xl font-bold text-stone-900 tracking-tight mb-4">Compress image guide for the current live pages</h1>
      <p class="text-stone-500 max-w-2xl mx-auto leading-relaxed">
        This guide explains the compression workflows that are live right now. Use it when you know you need a smaller upload, but you are not yet sure whether to choose a JPEG size page or the current PNG compression page.
      </p>
    </div>

    <section class="bg-white rounded-2xl p-7 shadow-soft border border-stone-100 mb-8 space-y-4">
      <h2 class="font-[var(--font-heading)] text-xl font-semibold text-stone-900">How to choose the right compression page</h2>
      <p class="text-stone-500 leading-relaxed">
        The live compression pages solve one clear problem: getting a static image under a file-size budget without uploading it to a server. JPEG pages work best when the file is a photo and quality-search compression is acceptable. The PNG page exists for images that need to stay PNG, such as screenshots, UI graphics, and transparent assets.
      </p>
      <p class="text-stone-500 leading-relaxed">
        The main difference is not just the number in the URL. JPEG pages aim for the requested budget by adjusting compression strength, while PNG pages keep PNG output and may reduce dimensions when that is the most reliable way to move toward the target. That means the best page depends on both your file type and the reason you need the smaller result.
      </p>
    </section>

    <section class="grid grid-cols-1 md:grid-cols-2 gap-5 mb-8">
      <div class="bg-white rounded-2xl p-6 shadow-soft border border-stone-100">
        <h2 class="font-[var(--font-heading)] text-lg font-semibold text-stone-900 mb-3">Choose a JPEG page when</h2>
        <ul class="space-y-3 text-sm text-stone-500 leading-relaxed list-disc pl-5">
          <li>You are working with a photo or camera image.</li>
          <li>The upload limit is strict, like 50KB or 200KB.</li>
          <li>You want the current tool to search for the lightest acceptable quality automatically.</li>
        </ul>
      </div>
      <div class="bg-white rounded-2xl p-6 shadow-soft border border-stone-100">
        <h2 class="font-[var(--font-heading)] text-lg font-semibold text-stone-900 mb-3">Choose the PNG page when</h2>
        <ul class="space-y-3 text-sm text-stone-500 leading-relaxed list-disc pl-5">
          <li>The image must stay in PNG format after processing.</li>
          <li>You care about transparency or screenshot clarity.</li>
          <li>You understand that the tool may reduce dimensions to reach a smaller budget.</li>
        </ul>
      </div>
    </section>

    <section class="bg-white rounded-2xl p-7 shadow-soft border border-stone-100 mb-10">
      <h2 class="font-[var(--font-heading)] text-xl font-semibold text-stone-900 mb-4">Current live compression pages</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        {compressRoutes.map((route) => (
          <a href={`/${route.slug}`} class="no-underline rounded-xl border border-stone-100 p-5 hover:border-teal-200 hover:bg-teal-50/40 transition-all">
            <h3 class="font-[var(--font-heading)] font-semibold text-stone-900 mb-2">{route.seo.h1}</h3>
            <p class="text-sm text-stone-500 leading-relaxed">{route.seo.subtitle}</p>
          </a>
        ))}
      </div>
    </section>

    <section class="grid grid-cols-1 md:grid-cols-2 gap-5">
      <a href="/supported-formats" class="no-underline bg-white rounded-2xl p-6 shadow-soft border border-stone-100 hover:border-teal-200 hover:bg-teal-50/40 transition-all">
        <h2 class="font-[var(--font-heading)] text-lg font-semibold text-stone-900 mb-2">Review current limits</h2>
        <p class="text-sm text-stone-500 leading-relaxed">Check what the live public site supports today before you promise a format or workflow to someone else.</p>
      </a>
      <a href="/" class="no-underline bg-white rounded-2xl p-6 shadow-soft border border-stone-100 hover:border-teal-200 hover:bg-teal-50/40 transition-all">
        <h2 class="font-[var(--font-heading)] text-lg font-semibold text-stone-900 mb-2">Use the homepage quick tool</h2>
        <p class="text-sm text-stone-500 leading-relaxed">If you do not need a fixed target-size page yet, start from the homepage tool and choose compression there.</p>
      </a>
    </section>
  </article>
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import ImageProcessor from '../components/ImageProcessor.tsx';
import { phase0Routes } from '../data/routes';

const title = 'LocalResizer — Free Online Image Resizer & Compressor | 100% Private';
const description = 'Resize and compress images instantly in your browser. No uploads, no servers — your files never leave your device. Free, fast, and private.';
---
<BaseLayout title={title} description={description}>
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <!-- Subtle background pattern -->
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_-10%,rgba(13,148,136,0.06),transparent_50%),radial-gradient(circle_at_70%_120%,rgba(245,158,11,0.04),transparent_50%)]" />

    <div class="relative max-w-3xl mx-auto px-5 pt-20 pb-10 text-center">
      <!-- Badge -->
      <div class="inline-flex items-center gap-2 px-3.5 py-1.5 rounded-full bg-white border border-stone-200 shadow-soft text-sm mb-8 animate-fade-up">
        <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse" />
        <span class="text-stone-500">100% browser-based</span>
        <span class="text-stone-300">&middot;</span>
        <span class="text-stone-500">No uploads</span>
      </div>

      <h1 class="font-[var(--font-heading)] text-4xl md:text-[3.25rem] font-extrabold leading-[1.1] tracking-tight text-stone-900 mb-5 animate-fade-up" style="animation-delay: 0.1s">
        Resize & Compress Images,<br />
        <span class="bg-gradient-to-r from-teal-600 to-emerald-500 bg-clip-text text-transparent">Right in Your Browser</span>
      </h1>

      <p class="text-lg text-stone-500 max-w-xl mx-auto mb-3 animate-fade-up" style="animation-delay: 0.15s">
        Your files never leave your device. No servers, no tracking, no nonsense.
      </p>

      <p class="text-sm text-stone-400 animate-fade-up" style="animation-delay: 0.2s">
        Free forever &middot; No sign-up required
      </p>
    </div>
  </section>

  <!-- Processor -->
  <div class="animate-fade-up" style="animation-delay: 0.25s">
    <ImageProcessor
      client:visible
      action="compress"
      acceptFormats={['image/jpeg', 'image/png', 'image/webp', 'image/gif']}
      maxFileSize={52428800}
    />
  </div>

  <!-- Features -->
  <section class="max-w-4xl mx-auto px-5 py-20">
    <div class="text-center mb-12">
      <span class="inline-block px-3 py-1 rounded-full bg-teal-50 text-teal-700 text-xs font-semibold tracking-wide uppercase mb-3">Why LocalResizer</span>
      <h2 class="font-[var(--font-heading)] text-2xl md:text-3xl font-bold text-stone-900 tracking-tight">Built for privacy-conscious creators</h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-5 stagger-children">
      <div class="bg-white rounded-2xl p-7 shadow-soft border border-stone-100 hover:shadow-soft-lg hover:-translate-y-0.5 transition-all duration-300">
        <div class="w-11 h-11 rounded-xl bg-emerald-50 flex items-center justify-center mb-4">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-emerald-600">
            <rect x="3" y="11" width="18" height="11" rx="2" ry="2" /><path d="M7 11V7a5 5 0 0 1 10 0v4" />
          </svg>
        </div>
        <h3 class="font-[var(--font-heading)] font-semibold text-stone-900 mb-2">100% Private</h3>
        <p class="text-sm text-stone-500 leading-relaxed">Files never leave your device. Zero server uploads, zero data collection. What happens in your browser stays in your browser.</p>
      </div>
      <div class="bg-white rounded-2xl p-7 shadow-soft border border-stone-100 hover:shadow-soft-lg hover:-translate-y-0.5 transition-all duration-300">
        <div class="w-11 h-11 rounded-xl bg-amber-50 flex items-center justify-center mb-4">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-amber-600">
            <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2" />
          </svg>
        </div>
        <h3 class="font-[var(--font-heading)] font-semibold text-stone-900 mb-2">Instant Processing</h3>
        <p class="text-sm text-stone-500 leading-relaxed">Browser-native Canvas API compression. No waiting for uploads or server queues. Results in seconds, not minutes.</p>
      </div>
      <div class="bg-white rounded-2xl p-7 shadow-soft border border-stone-100 hover:shadow-soft-lg hover:-translate-y-0.5 transition-all duration-300">
        <div class="w-11 h-11 rounded-xl bg-sky-50 flex items-center justify-center mb-4">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-sky-600">
            <circle cx="12" cy="12" r="10" /><path d="M12 6v6l4 2" />
          </svg>
        </div>
        <h3 class="font-[var(--font-heading)] font-semibold text-stone-900 mb-2">Precise Targeting</h3>
        <p class="text-sm text-stone-500 leading-relaxed">Hit exact file sizes with smart binary-search compression. Set your target — 50KB, 200KB, 2MB — and we'll nail it within 5%.</p>
      </div>
    </div>
  </section>

  <!-- Popular Tools -->
  <section class="max-w-4xl mx-auto px-5 pb-20">
    <div class="text-center mb-10">
      <span class="inline-block px-3 py-1 rounded-full bg-amber-50 text-amber-700 text-xs font-semibold tracking-wide uppercase mb-3">Tools</span>
      <h2 class="font-[var(--font-heading)] text-2xl md:text-3xl font-bold text-stone-900 tracking-tight">Popular Tools</h2>
    </div>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3 stagger-children">
      {phase0Routes.map(route => (
        <a
          href={`/${route.slug}`}
          class="group bg-white rounded-xl p-4 border border-stone-100 shadow-soft no-underline hover:shadow-soft-lg hover:border-teal-200 hover:-translate-y-0.5 transition-all duration-300"
        >
          <p class="text-sm font-medium text-stone-700 group-hover:text-teal-700 transition-colors leading-snug">{route.seo.h1}</p>
          <div class="mt-2 flex items-center gap-1 text-xs text-stone-400 group-hover:text-teal-500 transition-colors">
            <span>Try it</span>
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" class="translate-x-0 group-hover:translate-x-0.5 transition-transform">
              <path d="M2.5 6h7M7 3l2.5 3-2.5 3" />
            </svg>
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

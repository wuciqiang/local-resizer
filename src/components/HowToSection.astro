---
interface Props {
  steps: string[];
}
const { steps } = Astro.props;
---
<section class="max-w-3xl mx-auto px-5 py-16">
  <div class="text-center mb-10">
    <span class="inline-block px-3 py-1 rounded-full bg-teal-50 text-teal-700 text-xs font-semibold tracking-wide uppercase mb-3">Simple Process</span>
    <h2 class="font-[var(--font-heading)] text-2xl font-bold text-stone-900 tracking-tight">How It Works</h2>
  </div>
  <div class="grid grid-cols-1 md:grid-cols-3 gap-5 stagger-children">
    {steps.map((step, i) => (
      <div class="relative bg-white rounded-2xl p-6 shadow-soft border border-stone-100 text-center group hover:shadow-soft-lg hover:-translate-y-0.5 transition-all duration-300">
        <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-teal-500 to-teal-600 text-white flex items-center justify-center mx-auto mb-4 text-sm font-bold font-[var(--font-heading)] shadow-soft group-hover:scale-110 transition-transform duration-300">{i + 1}</div>
        <p class="text-stone-600 text-[15px] leading-relaxed">{step}</p>
      </div>
    ))}
  </div>
</section>

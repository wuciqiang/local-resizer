---
const { targetKB } = Astro.props;
---

<section class="demo-card">
  <div class="dropzone" data-dropzone>
    <p>Drop image here</p>
    <p class="hint">Client-side only. Nothing leaves the browser.</p>
    <input id="image-input" type="file" accept="image/*" />
  </div>

  <div class="controls">
    <label>
      Target size (KB)
      <input id="target-kb" type="number" min="1" value={targetKB} />
    </label>
    <button id="compress-button" type="button">Compress image</button>
  </div>

  <div class="result-grid">
    <div>
      <h2>Original</h2>
      <p id="original-meta">Waiting for image...</p>
    </div>
    <div>
      <h2>Compressed</h2>
      <p id="compressed-meta">No result yet.</p>
      <a id="download-link" href="#" download="compressed-image.jpg">Download output</a>
    </div>
  </div>
</section>

<script>
  import { compressImageToTarget } from '../lib/compress.ts';

  const input = document.querySelector('#image-input');
  const button = document.querySelector('#compress-button');
  const targetInput = document.querySelector('#target-kb');
  const originalMeta = document.querySelector('#original-meta');
  const compressedMeta = document.querySelector('#compressed-meta');
  const downloadLink = document.querySelector('#download-link');

  const formatKB = (bytes) => `${(bytes / 1024).toFixed(1)} KB`;

  button?.addEventListener('click', async () => {
    const file = input?.files?.[0];
    if (!file) {
      compressedMeta.textContent = 'Pick an image first.';
      return;
    }

    const targetKB = Number(targetInput?.value || 0);
    originalMeta.textContent = `${file.name} · ${formatKB(file.size)}`;
    compressedMeta.textContent = 'Compressing...';

    try {
      const blob = await compressImageToTarget(file, { targetKB });
      const url = URL.createObjectURL(blob);

      downloadLink.href = url;
      compressedMeta.textContent = `${formatKB(blob.size)} · target ${targetKB} KB`;
    } catch (error) {
      compressedMeta.textContent = error instanceof Error ? error.message : 'Compression failed.';
    }
  });
</script>

<style>
  .demo-card {
    border: 1px solid #d7dce5;
    border-radius: 24px;
    padding: 24px;
    background: #fff;
    box-shadow: 0 20px 40px rgba(15, 23, 42, 0.06);
  }

  .dropzone {
    min-height: 280px;
    border: 2px dashed #7c3aed;
    border-radius: 20px;
    display: grid;
    place-items: center;
    text-align: center;
    margin-bottom: 20px;
    background: linear-gradient(180deg, #f5f3ff, #ffffff);
  }

  .hint {
    color: #64748b;
    font-size: 0.95rem;
  }

  .controls {
    display: flex;
    gap: 16px;
    align-items: end;
    flex-wrap: wrap;
    margin-bottom: 20px;
  }

  input,
  button {
    font: inherit;
  }

  input[type='number'],
  input[type='file'] {
    display: block;
    margin-top: 8px;
  }

  button {
    background: #111827;
    color: #fff;
    border: 0;
    border-radius: 12px;
    padding: 12px 18px;
    cursor: pointer;
  }

  .result-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 20px;
  }

  #download-link {
    color: #7c3aed;
  }
</style>

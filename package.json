{
  "name": "local-resizer",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "build:deploy": "npm run build && npm run submit-indexnow",
    "preview": "astro preview",
    "typecheck": "astro check && tsc --noEmit",
    "test": "vitest run",
    "test:routes": "vitest run tests/routes.test.ts",
    "test:content": "vitest run tests/content.test.ts",
    "test:seo": "vitest run tests/seo.test.ts",
    "test:image": "vitest run tests/image-geometry.test.ts tests/image-processor-utils.test.ts",
    "smoke:dist": "node scripts/check-dist.js",
    "verify": "npm run typecheck && npm run test && npm run build && npm run smoke:dist",
    "submit-indexnow": "node scripts/submit-indexnow.js"
  },
  "dependencies": {
    "@astrojs/react": "^4.2.1",
    "@astrojs/sitemap": "^3.3.1",
    "astro": "^5.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "fast-xml-parser": "^5.5.3",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
